# ==========================================
# AREA Platform - Environment Variables
# ==========================================

# Node Environment
NODE_ENV=development
PORT=5000

# ==========================================
# Database Configuration
# ==========================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=areauser
DB_PASSWORD=areapass
DB_NAME=area_db
DATABASE_URL=postgresql://areauser:areapass@localhost:5432/area_db

# ==========================================
# Redis Configuration
# ==========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379

# ==========================================
# JWT Configuration
# ==========================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production-12345
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-refresh-secret-key-12345
JWT_REFRESH_EXPIRES_IN=30d

# ==========================================
# OAuth2 Providers Configuration
# ==========================================

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/oauth/google/callback

# GitHub OAuth
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_CALLBACK_URL=http://localhost:5000/api/auth/oauth/github/callback

# Twitter/X OAuth
TWITTER_CLIENT_ID=your-twitter-client-id
TWITTER_CLIENT_SECRET=your-twitter-client-secret
TWITTER_CALLBACK_URL=http://localhost:5000/api/auth/oauth/twitter/callback

# Discord OAuth
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret
DISCORD_CALLBACK_URL=http://localhost:5000/api/auth/oauth/discord/callback

# ==========================================
# API URLs Configuration
# ==========================================
API_URL=http://localhost:5000
WEB_URL=http://localhost:3000
MOBILE_URL=http://localhost:3001

# ==========================================
# Email Configuration
# ==========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@area-platform.com

# ==========================================
# Service Tokens (for Actions/REActions)
# ==========================================

# RSS Feed
RSS_API_KEY=optional-rss-api-key

# Custom Webhooks
WEBHOOK_TIMEOUT=30000
WEBHOOK_MAX_RETRIES=3

# ==========================================
# Logging Configuration
# ==========================================
LOG_LEVEL=info
LOG_FORMAT=json

# ==========================================
# Security
# ==========================================
CORS_ORIGIN=http://localhost:3000,http://localhost:3001
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
SESSION_SECRET=your-session-secret-12345

# ==========================================
# Feature Flags
# ==========================================
ENABLE_REGISTRATION=true
ENABLE_OAUTH=true
ENABLE_EMAIL_VERIFICATION=true
ENABLE_WORKFLOW_SCHEDULER=true
ENABLE_ANALYTICS=true

# ==========================================
# Development Tools
# ==========================================
DEBUG=area:*
ENABLE_SWAGGER=true
ENABLE_METRICS=true
